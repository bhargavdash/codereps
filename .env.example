# ── apps/api (copy to apps/api/.env) ──────────────────────────────
PORT=4000
WEB_ORIGIN=http://localhost:5173      # CORS allowlist (prod: the Vercel URL)
SUPABASE_URL=https://<project>.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=            # server-only, never exposed to web
SUPABASE_JWT_SECRET=                  # only for legacy HS256 projects; leave empty to use JWKS

# ── packages/db (copy to packages/db/.env) ────────────────────────
# Always-on Express server → direct connection is correct (no pooler needed).
DATABASE_URL=postgresql://postgres:<password>@db.<project>.supabase.co:5432/postgres
DIRECT_URL=postgresql://postgres:<password>@db.<project>.supabase.co:5432/postgres

# ── apps/web (copy to apps/web/.env) — Vite exposes VITE_* only ───
VITE_SUPABASE_URL=https://<project>.supabase.co
VITE_SUPABASE_ANON_KEY=
VITE_API_URL=http://localhost:4000
