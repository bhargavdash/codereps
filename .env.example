# Supabase config replicated exactly from nomad-api/nomad-web: new-style
# publishable/secret keys (not legacy anon/service_role), Session pooler
# connection string, JWKS-based auth verification (no secret key needed
# server-side at all — see apps/api/src/middleware/auth.ts).

# ── apps/api (copy to apps/api/.env) ──────────────────────────────
PORT=4000
WEB_ORIGIN=http://localhost:5173      # CORS allowlist (prod: the Vercel URL)

# Dashboard → Settings → API → Project URL
SUPABASE_URL=https://<project-ref>.supabase.co

# ── packages/db (copy to packages/db/.env) ────────────────────────
# Session mode pooler — supports IPv4 + IPv6, prepared statements (port 5432)
# Dashboard → Connect button → Session pooler → copy URI
DATABASE_URL=postgres://postgres.<project-ref>:[YOUR-PASSWORD]@aws-0-<region>.pooler.supabase.com:5432/postgres

# ── apps/web (copy to apps/web/.env) — Vite exposes VITE_* only ───
VITE_SUPABASE_URL=https://<project-ref>.supabase.co
# Dashboard → Settings → API Keys → Publishable keys tab
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...
VITE_API_URL=http://localhost:4000
