{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**"]
    },
    "typecheck": {
      "dependsOn": ["^build"]
    },
    "test": {
      "dependsOn": ["^build"]
    },
    "//#lint": {
      "dependsOn": ["@codereps/shared#build"],
      "inputs": ["content/**", "scripts/verify-content.ts"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    }
  }
}
